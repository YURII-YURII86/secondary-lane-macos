# Для локальной установки и pytest сейчас подтверждён python3.13.
# Это главный секрет для доступа к агенту через интернет.
# Замени значение справа от = на длинный случайный набор символов.
# Не используй change-me, default, 12345 и другие простые слова.
AGENT_TOKEN=replace-this-with-a-long-random-secret-token
AGENT_HOST=0.0.0.0
AGENT_PORT=8787
# Укажи свои корневые каталоги, к которым GPT можно давать доступ.
WORKSPACE_ROOTS=/Users/your-name/Documents:/workspace:/projects
# Опционально: allowlist для SSH. Оставь [] если не используешь удалённые хосты.
SSH_ALLOWED_HOSTS_JSON=[]
SSH_ALLOWED_CIDRS_JSON=[]
# Опционально: по умолчанию ядро и так использует repo-local пути.
# ENABLED_PROVIDER_MANIFESTS=/absolute/path/to/app/providers
# STATE_DB_PATH=/absolute/path/to/data/agent.db
MAX_OUTPUT_CHARS=50000
MAX_FILE_BYTES=1048576
DEFAULT_TIMEOUT_SEC=30
# Tunnel: ngrok (бесплатный статический домен, создаётся в dashboard.ngrok.com → Domains)
# Перед первым запуском: brew install ngrok && ngrok config add-authtoken <YOUR_TOKEN>
NGROK_DOMAIN=your-domain.ngrok-free.dev
SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts
GUI_ALLOWED_APPS_JSON=["Google Chrome","Finder","Terminal","Visual Studio Code"]
# Опционально: переменные провайдеров. Ядро от них не зависит.
# PROVIDER_GITHUB_TOKEN=
# PROVIDER_VERCEL_TOKEN=
# PROVIDER_RAILWAY_TOKEN=
